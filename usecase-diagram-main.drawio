<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="boundary" value="SystemVote - Voting Platform" style="shape=rectangle;html=1;rounded=0;whiteSpace=wrap;strokeWidth=3;fillColor=none;strokeColor=#000000;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="40" width="1000" height="700" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ACTORS (Left side) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Guest Actor -->
    <mxCell id="actor1" value="Guest" style="shape=ellipse;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="150" width="60" height="80" as="geometry"/>
    </mxCell>

    <!-- Registered User Actor -->
    <mxCell id="actor2" value="Registered User" style="shape=ellipse;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="300" width="60" height="80" as="geometry"/>
    </mxCell>

    <!-- Room Owner Actor -->
    <mxCell id="actor3" value="Room Owner" style="shape=ellipse;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="450" width="60" height="80" as="geometry"/>
    </mxCell>

    <!-- Participant Actor -->
    <mxCell id="actor4" value="Participant" style="shape=ellipse;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="600" width="60" height="80" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- USE CASES - AUTHENTICATION (Top) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Register Account -->
    <mxCell id="uc1" value="Register Account" style="ellipse;html=1;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
