    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Join Room includes Enter Username -->
    <mxCell id="inc1" value="&lt;&lt;include&gt;&gt;" style="endArrow=open;dashed=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=9;" edge="1" parent="1" source="uc13" target="uc14"/>

