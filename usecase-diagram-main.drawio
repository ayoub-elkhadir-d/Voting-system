    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ASSOCIATIONS - GUEST -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <mxCell id="assoc1" style="endArrow=none;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="actor1" target="uc1"/>
    <mxCell id="assoc2" style="endArrow=none;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="actor1" target="uc2"/>

